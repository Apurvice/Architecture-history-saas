{
  "name": "Architecture-History-SaaS",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
      "pnpm": "latest"
    }
  },
  "postCreateCommand": "echo 'Setup complete! Your architecture SaaS environment is ready.'",
  "forwardPorts": [3000, 8000],
  "portsAttributes": {
    "3000": {
      "label": "OpenMAIC Platform",
      "onAutoForward": "openPreview"
    },
    "8000": {
      "label": "Admin Panel"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "GitHub.copilot",
        "GitHub.copilot-chat",
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "PKief.material-icon-theme"
      ]
    }
  }
}
